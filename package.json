{
  "name": "resume-matcher",
  "private": true,
  "workspaces": ["frontend", "backend"],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=@resume-matcher/frontend",
    "dev:backend": "npm run dev --workspace=@resume-matcher/backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "build:frontend": "npm run build --workspace=@resume-matcher/frontend",
    "build:backend": "npm run build --workspace=@resume-matcher/backend",
    "test:backend": "npm run test --workspace=@resume-matcher/backend",
    "test:frontend": "npm run test --workspace=@resume-matcher/frontend",
    "test": "npm run test:backend && npm run test:frontend"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
