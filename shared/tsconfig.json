  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "verbatimModuleSyntax": true,
    "composite": true,
    "declaration": true
  },
  "include": ["types/**/*", "constants/**/*"]
}